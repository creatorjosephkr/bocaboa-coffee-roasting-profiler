{
  "name": "bocaboa-profiler",
  "version": "2.0.0",
  "description": "BocaBoa Coffee Roasting Profiler - Cross Platform (Windows & macOS)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac-arm": "electron-builder --mac --arm64 -c.mac.artifactName=\"BocaBoa-v2.0-macOS-ARM.dmg\"",
    "build:mac-intel": "electron-builder --mac --x64 -c.mac.artifactName=\"BocaBoa-v2.0-macOS-intel.dmg\"",
    "build:win-intel": "electron-builder --win --x64 -c.win.artifactName=\"BocaBoa-v2.0-Windows-intel.exe\"",
    "build:win-arm": "electron-builder --win --arm64 -c.win.artifactName=\"BocaBoa-v2.0-Windows-ARM.exe\"",
    "dist": "npm run build:mac-arm && npm run build:mac-intel && npm run build:win-intel && npm run build:win-arm"
  },
  "keywords": [
    "coffee",
    "roasting",
    "profiler",
    "electron"
  ],
  "author": "creatorjoseph@kakao.com",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26"
  },
  "build": {
    "appId": "com.bocaboa.profiler",
    "productName": "BocaBoa2",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "background": "build/dmg_background.png",
      "iconSize": 100,
      "window": {
        "width": 600,
        "height": 400
      },
      "contents": [
        {
          "x": 150,
          "y": 180,
          "type": "file"
        },
        {
          "x": 450,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
